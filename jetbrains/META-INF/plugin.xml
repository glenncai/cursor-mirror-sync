<idea-plugin require-restart="false">
  <version>1.0.0</version>
  <idea-version since-build="233" />
  <id>com.glenncai.cursormirrorsync</id>
  <name>Cursor Mirror Sync</name>
  <vendor url="https://github.com/glenncai">Glenn Cai</vendor>
  <description><![CDATA[Stop losing your place when switching between VSCode and JetBrains IDEs]]></description>
  <depends>com.intellij.modules.platform</depends>
  <change-notes><![CDATA[Version 1.0.0]]></change-notes>
  <extensions defaultExtensionNs="com.intellij">
    <!-- Status bar widget factory -->
    <statusBarWidgetFactory implementation="com.glenncai.cursormirrorsync.ui.StatusBarWidgetFactory" id="CursorMirrorSync" />
    <!-- Notification group -->
    <notificationGroup id="Cursor Mirror Sync" displayType="BALLOON" />
    <!-- Settings configurable -->
    <projectConfigurable parentId="tools" instance="com.glenncai.cursormirrorsync.ui.SettingsConfigurable" id="CursorMirrorSyncConfigurable" displayName="Cursor Mirror Sync" />
  </extensions>
  <!-- Plugin's project components -->
  <projectListeners>
    <listener class="com.glenncai.cursormirrorsync.SyncPlugin" topic="com.intellij.openapi.startup.ProjectActivity" />
  </projectListeners>
</idea-plugin>
